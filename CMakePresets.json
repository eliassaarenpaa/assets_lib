{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja-clang",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "ninja",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld",
        "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "VCPKG_MANIFEST_INSTALL": false,
        "CMAKE_COLOR_DIAGNOSTICS": "ON"
      }
    },
    {
      "name": "base-vcpkg",
      "hidden": true,
      "inherits": "base-ninja-clang",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_APPLOCAL_DEPS": "ON",
        "CMAKE_EXE_LINKER_FLAGS": "",
        "CMAKE_SHARED_LINKER_FLAGS": ""
      }
    },
    {
      "name": "base-debug",
      "hidden": true,
      "inherits": "base-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-O0 -g -Xclang -gcodeview",
        "CMAKE_C_FLAGS": "-O0 -g -Xclang -gcodeview"
      }
    },
    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS": "-O3 -flto=thin -march=native",
        "CMAKE_C_FLAGS": "-O3 -flto=thin -march=native"
      }
    },
    {
      "name": "dev-debug",
      "displayName": "Dev Debug",
      "inherits": "base-debug",
      "binaryDir": "${sourceDir}/build/dev-debug",
      "cacheVariables": {
        "DEV": "ON"
      }
    },
    {
      "name": "dev-release",
      "displayName": "Dev Release",
      "inherits": "base-release",
      "binaryDir": "${sourceDir}/build/dev-release",
      "cacheVariables": {
        "DEV": "ON"
      }
    },
    {
      "name": "export-debug",
      "displayName": "Export Debug",
      "inherits": "base-debug",
      "binaryDir": "${sourceDir}/build/export-debug",
      "cacheVariables": {
        "DEV": "OFF"
      }
    },
    {
      "name": "export-release",
      "displayName": "Export Release",
      "inherits": "base-release",
      "binaryDir": "${sourceDir}/build/export-release",
      "cacheVariables": {
        "DEV": "OFF"
      }
    },
    {
      "name": "vcpkg",
      "displayName": "vcpkg (install only)",
      "inherits": "base-vcpkg",
      "binaryDir": "${sourceDir}/out/build/${presetName}"
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug",
      "jobs": 0
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release",
      "jobs": 0
    },
    {
      "name": "export-debug",
      "configurePreset": "export-debug",
      "jobs": 0
    },
    {
      "name": "export-release",
      "configurePreset": "export-release",
      "jobs": 0
    }
  ]
}
